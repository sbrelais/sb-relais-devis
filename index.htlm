<script>
  // Indicatifs téléphoniques par pays
  const indicatifs = {
    "Côte d'Ivoire 🇨🇮": "+225", "Sénégal 🇸🇳": "+221", "Mali 🇲🇱": "+223",
    "Guinée 🇬🇳": "+224", "Burkina Faso 🇧🇫": "+226", "Togo 🇹🇬": "+228",
    "Bénin 🇧🇯": "+229", "Niger 🇳🇪": "+227", "Ghana 🇬🇭": "+233",
    "Nigeria 🇳🇬": "+234", "Mauritanie 🇲🇷": "+222", "Sierra Leone 🇸🇱": "+232",
    "Liberia 🇱🇷": "+231", "Guinée-Bissau 🇬🇼": "+245", "Gambie 🇬🇲": "+220",
    "Cap-Vert 🇨🇻": "+238", "Cameroun 🇨🇲": "+237", "Congo-Brazzaville 🇨🇬": "+242",
    "RD Congo 🇨🇩": "+243", "Gabon 🇬🇦": "+241", "Tchad 🇹🇩": "+235",
    "République Centrafricaine 🇨🇫": "+236", "Guinée Équatoriale 🇬🇶": "+240",
    "São Tomé-et-Príncipe 🇸🇹": "+239", "Éthiopie 🇪🇹": "+251", "Kenya 🇰🇪": "+254",
    "Tanzanie 🇹🇿": "+255", "Rwanda 🇷🇼": "+250", "Ouganda 🇺🇬": "+256",
    "Burundi 🇧🇮": "+257", "Somalie 🇸🇴": "+252", "Djibouti 🇩🇯": "+253",
    "Érythrée 🇪🇷": "+291", "Soudan 🇸🇩": "+249", "Soudan du Sud 🇸🇸": "+211",
    "Madagascar 🇲🇬": "+261", "Comores 🇰🇲": "+269", "Seychelles 🇸🇨": "+248",
    "Maurice 🇲🇺": "+230", "Maroc 🇲🇦": "+212", "Algérie 🇩🇿": "+213",
    "Tunisie 🇹🇳": "+216", "Libye 🇱🇾": "+218", "Égypte 🇪🇬": "+20",
    "Afrique du Sud 🇿🇦": "+27", "Angola 🇦🇴": "+244", "Mozambique 🇲🇿": "+258",
    "Zambie 🇿🇲": "+260", "Zimbabwe 🇿🇼": "+263", "Malawi 🇲🇼": "+265",
    "Namibie 🇳🇦": "+264", "Botswana 🇧🇼": "+267", "Lesotho 🇱🇸": "+266",
    "Eswatini 🇸🇿": "+268"
  };

  document.getElementById('pays').addEventListener('change', function() {
    const pays = this.value;
    const indicatif = indicatifs[pays] || '';
    const span = document.getElementById('tel-indicatif');
    span.textContent = indicatif || '🌍';
    // Pré-remplir le champ tel si vide
    const telInput = document.getElementById('tel');
    if (indicatif && telInput.value === '') {
      telInput.placeholder = indicatif.replace('+', '') + ' 00 00 00 00';
    }
  });
  document.querySelectorAll('input[name="voie"]').forEach(r => {
    r.addEventListener('change', () => {
      const blocPoids = document.getElementById('bloc-poids');
      blocPoids.classList.toggle('visible', r.value === 'aerien' && r.checked);
      filtrerArticlesParVoie(r.value);
      updateBlocValeur();
    });
  });

  function filtrerArticlesParVoie(voie) {
    const sel = document.getElementById('article');
    const optDoc = sel.querySelector('option[value="documents"]');
    if (voie === 'maritime') {
      // Désactiver et masquer Documents
      optDoc.disabled = true;
      optDoc.style.display = 'none';
      // Si documents était sélectionné, réinitialiser
      if (sel.value === 'documents') {
        sel.value = '';
        updateBlocValeur();
        document.getElementById('hint-meubles').style.display = 'none';
        document.getElementById('bloc-autre-article').classList.remove('visible');
      }
    } else {
      optDoc.disabled = false;
      optDoc.style.display = '';
    }
  }

  // Article → hints + blocs conditionnels
  document.getElementById('article').addEventListener('change', function() {
    const v = this.value;
    document.getElementById('hint-meubles').style.display = v === 'meubles' ? 'block' : 'none';
    document.getElementById('bloc-autre-article').classList.toggle('visible', v === 'autre');
    updateBlocValeur();
  });

  // Bloc valeur : masqué pour livres, documents, médicaments
  function updateBlocValeur() {
    const article = document.getElementById('article').value;
    const sans = ['livres', 'documents', 'medicaments', 'meubles', ''];
    document.getElementById('bloc-valeur').classList.toggle('visible', !sans.includes(article));
  }

  // Transporteur oui/non
  document.querySelectorAll('input[name="transporteur"]').forEach(r => {
    r.addEventListener('change', () => {
      document.getElementById('bloc-transporteur-oui').classList.toggle('visible', r.value === 'oui' && r.checked);
      document.getElementById('bloc-transporteur-non').classList.toggle('visible', r.value === 'non' && r.checked);
    });
  });

  const labelsArticle = {
    vetements: 'Vêtements & accessoires de mode',
    cosmetiques: 'Cosmétiques & produits de beauté',
    electronique: 'Électronique & high-tech',
    jouets: 'Jouets & articles enfants',
    livres: 'Livres',
    documents: 'Documents',
    medicaments: 'Médicaments',
    meubles: 'Meubles & mobilier',
    equipement: 'Équipement professionnel',
    autre: 'Autre',
  };

  function validateField(id, condition) {
    const el = document.getElementById(id) || document.getElementById('f-' + id);
    const field = el && el.classList.contains('field') ? el : document.getElementById('f-' + id);
    if (field) {
      if (!condition) { field.classList.add('invalid'); return false; }
      else { field.classList.remove('invalid'); return true; }
    }
    return condition;
  }

  function fmt(n) { return n.toFixed(2).replace('.', ',') + ' €'; }

  function genererDevis() {
    let valid = true;

    valid &= validateField('nom', document.getElementById('nom').value.trim() !== '');
    valid &= validateField('prenom', document.getElementById('prenom').value.trim() !== '');
    valid &= validateField('pays', document.getElementById('pays').value !== '');

    // Validation téléphone : obligatoire + min 6 chiffres
    const telVal = document.getElementById('tel').value.trim().replace(/\s/g, '');
    const telOk = telVal !== '' && /^\d{6,15}$/.test(telVal);
    valid &= validateField('tel', telOk);
    if (telVal !== '' && !telOk) {
      document.querySelector('#f-tel .field-error').textContent = 'Numéro invalide (6 à 15 chiffres requis).';
    } else {
      document.querySelector('#f-tel .field-error').textContent = 'Ce champ est obligatoire.';
    }
    valid &= validateField('article', document.getElementById('article').value !== '');

    const article = document.getElementById('article').value;

    if (article === 'autre') {
      valid &= validateField('article-autre', document.getElementById('article-autre').value.trim() !== '');
    }

    const voie = document.querySelector('input[name="voie"]:checked');
    if (!voie) { valid = false; alert('Veuillez sélectionner une voie d\'expédition.'); }

    // Poids obligatoire pour aérien sauf livres/documents/médicaments
    const sansPoids = ['livres', 'documents', 'medicaments', 'meubles'];
    if (voie && voie.value === 'aerien' && !sansPoids.includes(article)) {
      valid &= validateField('poids', document.getElementById('poids').value !== '');
    }

    // Valeur obligatoire sauf livres/documents/médicaments/meubles
    const sansValeur = ['livres', 'documents', 'medicaments', 'meubles'];
    if (!sansValeur.includes(article)) {
      valid &= validateField('valeur', document.getElementById('valeur').value !== '');
      valid &= validateField('etat', document.getElementById('etat').value !== '');
    }

    const transporteur = document.querySelector('input[name="transporteur"]:checked');
    if (!transporteur) { valid = false; alert('Veuillez indiquer si vous avez un transporteur.'); }

    if (transporteur && transporteur.value === 'oui') {
      valid &= validateField('tr-nom', document.getElementById('tr-nom').value.trim() !== '');
      const trTelVal = document.getElementById('tr-tel').value.trim().replace(/\s/g, '');
      const trTelOk = /^(\+33|0033|0)[1-9](\d{8})$/.test(trTelVal);
      valid &= validateField('tr-tel', trTelOk);
      if (!trTelOk) {
        document.querySelector('#f-tr-tel .field-error').textContent = 'Numéro français invalide (ex : 01 23 45 67 89, 06 12 34 56 78 ou +33 1 23 45 67 89).';
      }
    }

    // Validation RGPD
    const rgpdChecked = document.getElementById('rgpd-check').checked;
    const rgpdError = document.getElementById('rgpd-error');
    if (!rgpdChecked) {
      rgpdError.classList.add('visible');
      valid = false;
    } else {
      rgpdError.classList.remove('visible');
    }

    if (!valid) return;

    // ── DONNÉES ──
    const nom     = document.getElementById('nom').value.trim();
    const prenom  = document.getElementById('prenom').value.trim();
    const pays    = document.getElementById('pays').value;
    const poids   = parseFloat(document.getElementById('poids').value) || 0;
    const valeur  = parseFloat(document.getElementById('valeur').value) || 0;
    const etat    = document.getElementById('etat').value;
    const trNom   = document.getElementById('tr-nom').value.trim();

    const articleLabel = article === 'autre'
      ? document.getElementById('article-autre').value.trim()
      : (labelsArticle[article] || article);

    // ── CALCULS TARIFAIRES ──
    let prestation = 150;
    let transport  = null;
    let douane     = 0;
    let showTotal  = false;

    const aerienSansPoids = ['livres', 'documents', 'medicaments', 'meubles'];

    if (voie.value === 'aerien') {
      if (article === 'documents') {
        prestation = 25;
        transport  = 20;
        showTotal  = true;
      } else if (article === 'livres') {
        prestation = 150;
        transport  = null;
      } else {
        // Prestation selon poids : 0–3 kg = 30€, +3 kg = 75€
        prestation = poids <= 3 ? 30 : 75;
        // Transport aérien : forfait 25€ pour 0–2,5 kg, sinon poids total × 11€
        transport = poids <= 2.5 ? 25 : poids * 11;
        showTotal = true;
      }
    } else {
      // Maritime (hors meubles)
      if (article !== 'meubles') {
        // 110€ uniquement via partenaire SB-Relais (pas de transporteur désigné ET pays CI)
        const paysCI_calc = document.getElementById('pays').value.startsWith("Côte d'Ivoire");
        const aTransporteur_calc = document.querySelector('input[name="transporteur"]:checked')?.value === 'oui';
        if (!aTransporteur_calc && paysCI_calc) {
          transport = 110;
          showTotal = true;
        } else {
          transport = null;
          showTotal = false;
        }
      } else {
        transport = null;
      }
    }

    // Douane : 10% sur articles neufs hors médicaments, documents, livres ET hors maritime
    const exoneresDouane = ['documents', 'medicaments', 'livres'];
    if (voie.value !== 'maritime' && !exoneresDouane.includes(article) && etat === 'neuf' && valeur > 0) {
      douane = valeur * 0.1;
    }

    // ── AFFICHAGE RÉSULTAT ──
    document.getElementById('res-client').textContent   = prenom + ' ' + nom.toUpperCase();
    document.getElementById('res-pays').textContent     = pays;
    document.getElementById('res-article').textContent  = articleLabel;
    document.getElementById('res-voie').textContent     = voie.value === 'maritime' ? '🚢 Voie maritime' : '✈️ Voie aérienne';

    // Prestation
    document.getElementById('res-prestation').textContent = fmt(prestation);

    // Poids / carton
    const poidsRow  = document.getElementById('res-poids-row');
    const cartonRow = document.getElementById('res-carton-row');
    const paysCI_affichage = pays.startsWith("Côte d'Ivoire");
    if (voie.value === 'aerien' && poids && !sansPoids.includes(article)) {
      poidsRow.style.display  = 'flex';
      cartonRow.style.display = 'none';
      document.getElementById('res-poids').textContent = poids + ' kg';
    } else if (voie.value === 'maritime' && paysCI_affichage) {
      poidsRow.style.display  = 'none';
      cartonRow.style.display = 'flex';
    } else {
      poidsRow.style.display  = 'none';
      cartonRow.style.display = 'none';
    }

    // Transport
    if (transport !== null) {
      document.getElementById('res-transport').innerHTML = '<strong>' + fmt(transport) + '</strong>';
    } else if (article === 'meubles') {
      document.getElementById('res-transport').innerHTML = '<span style="color:var(--brun-light);font-size:12px;">Devis personnalisé — un conseiller vous contactera</span>';
    } else if (article === 'livres') {
      document.getElementById('res-transport').innerHTML = '<span style="color:var(--brun-light);font-size:12px;">Selon conditions tarifaires du transporteur</span>';
    } else {
      document.getElementById('res-transport').innerHTML = '<span style="color:var(--brun-light);font-size:12px;">Sur devis — communiqué par notre conseiller</span>';
    }

    // Transporteur désigné
    const paysCI = pays.startsWith("Côte d'Ivoire");
    const aTransporteur = transporteur.value === 'oui';

    if (aTransporteur) {
      document.getElementById('res-transporteur').textContent = trNom + ' (transporteur désigné par le client)';
    } else {
      document.getElementById('res-transporteur').textContent = paysCI
        ? 'Partenaire SB-Relais (Côte d\'Ivoire 🇨🇮)'
        : 'Aucun — Contact à nous transmettre';
    }

    const transporteurDisponible = aTransporteur || paysCI;

    // Transport
    if (!transporteurDisponible) {
      document.getElementById('res-transport').innerHTML =
        '<span style="color:var(--brun-mid);font-size:13px;font-weight:400;">Le montant sera fonction de votre transporteur</span>';
      document.getElementById('res-douane-row').style.display = 'none';
      document.getElementById('res-total-row').style.display = 'none';
    } else if (transport !== null) {
      document.getElementById('res-transport').innerHTML = '<strong>' + fmt(transport) + '</strong>';
    } else if (article === 'meubles') {
      document.getElementById('res-transport').innerHTML = '<span style="color:var(--brun-light);font-size:12px;">Devis personnalisé — un conseiller vous contactera</span>';
    } else if (article === 'livres') {
      document.getElementById('res-transport').innerHTML = '<span style="color:var(--brun-light);font-size:12px;">Selon conditions tarifaires du transporteur</span>';
    } else if (aTransporteur) {
      document.getElementById('res-transport').innerHTML = '<span style="color:var(--brun-mid);font-size:13px;font-weight:400;">Tarif de votre transporteur à appliquer</span>';
    } else {
      document.getElementById('res-transport').innerHTML = '<span style="color:var(--brun-mid);font-size:13px;font-weight:400;">Le montant sera fonction de votre transporteur</span>';
    }

    // Douane
    const douaneRow = document.getElementById('res-douane-row');
    if (douane > 0 && transporteurDisponible) {
      douaneRow.style.display = 'flex';
      document.getElementById('res-douane').textContent = '≈ ' + fmt(douane) + ' (sur valeur déclarée de ' + fmt(valeur) + ')';
    } else {
      douaneRow.style.display = 'none';
    }

    // Total
    const totalRow = document.getElementById('res-total-row');
    if (showTotal && transport !== null && transporteurDisponible) {
      const total = prestation + transport + douane;
      totalRow.style.display = 'flex';
      document.getElementById('res-total').textContent = fmt(total);
    } else {
      totalRow.style.display = 'none';
    }

    // Date
    const now = new Date();
    const dateStr = now.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
    document.getElementById('res-date').textContent = 'Simulation du ' + dateStr;

    document.getElementById('resultat').classList.add('visible');
    document.getElementById('resultat').scrollIntoView({ behavior: 'smooth', block: 'start' });

    // ── ENVOI ZAPIER WEBHOOK ──
    const totalFinal = (showTotal && transport !== null && transporteurDisponible)
      ? fmt(prestation + transport + douane)
      : 'Sur devis';

    const transportLabel = transport !== null && transporteurDisponible
      ? fmt(transport)
      : (aTransporteur ? 'Tarif transporteur client' : 'Le montant sera fonction de votre transporteur');

    const payload = {
      date:              dateStr,
      nom:               prenom + ' ' + nom.toUpperCase(),
      pays_destination:  pays,
      telephone:         document.getElementById('tel-indicatif').textContent + ' ' + document.getElementById('tel').value.trim(),
      email:             document.getElementById('email').value.trim() || '—',
      article:           articleLabel,
      voie_expedition:   voie.value === 'maritime' ? 'Maritime' : 'Aérienne',
      poids_kg:          voie.value === 'aerien' && poids ? poids + ' kg' : '—',
      valeur_declaree:   valeur > 0 ? fmt(valeur) : '—',
      etat_article:      etat === 'neuf' ? 'Neuf' : etat === 'occasion' ? 'Occasion' : '—',
      transporteur:      aTransporteur ? trNom + ' — ' + document.getElementById('tr-tel').value.trim() : 'Aucun',
      frais_prestation:  fmt(prestation),
      frais_transport:   transportLabel,
      frais_douane:      douane > 0 ? fmt(douane) : '—',
      total_estime:      totalFinal,
      rgpd:              'Accepté'
    };

    fetch('https://hooks.zapier.com/hooks/catch/27159720/u7zto8s/', {
      method: 'POST',
      body: JSON.stringify(payload),
      headers: { 'Content-Type': 'application/json' }
    })
    .then(r => {
      if (!r.ok) console.warn('Zapier webhook: erreur envoi', r.status);
      else console.log('Zapier: données envoyées avec succès');
    })
    .catch(e => console.warn('Zapier webhook: erreur réseau', e));
  }

  function resetForm() {
    document.querySelectorAll('input[type="text"], input[type="tel"], input[type="email"], input[type="number"]').forEach(i => i.value = '');
    document.querySelectorAll('select').forEach(s => s.value = '');
    document.querySelectorAll('input[type="radio"]').forEach(r => r.checked = false);
    document.querySelectorAll('.conditional').forEach(c => c.classList.remove('visible'));
    document.querySelectorAll('.field').forEach(f => f.classList.remove('invalid'));
    document.getElementById('hint-meubles').style.display = 'none';
    document.getElementById('rgpd-check').checked = false;
    document.getElementById('rgpd-error').classList.remove('visible');
    document.getElementById('resultat').classList.remove('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>

</body>
</html>