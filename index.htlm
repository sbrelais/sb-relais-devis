  </div>

  <!-- RÉSULTAT -->

  <div id="resultat">
    <div class="resultat-card">
      <div class="resultat-header">
        <h2>Votre devis SB-Relais</h2>
        <p id="res-date"></p>
      </div>

```
  <div class="resultat-body">

    <!-- Récap client -->
    <div class="recap-row">
      <span class="recap-label">Client</span>
